<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Panda Clicker: Golden Edition</title>
    <style>
        body { 
            text-align: center; font-family: 'Arial Rounded MT Bold', sans-serif; 
            background: linear-gradient(135deg, #f5f5dc, #d4e157); 
            height: 100vh; margin: 0; display: flex; align-items: center; justify-content: center;
        }
        #game-box { 
            background: rgba(255, 255, 255, 0.9); padding: 30px; border-radius: 30px; 
            box-shadow: 0 20px 50px rgba(0,0,0,0.2); width: 420px; border: 4px solid #558b2f;
        }
        .stats { font-size: 36px; color: #2e7d32; margin-bottom: 5px; }
        .golden-stats { color: #f9a825; font-size: 18px; margin-bottom: 20px; font-weight: bold; }
        
        #panda-btn { 
            width: 160px; cursor: pointer; transition: transform 0.1s; 
            user-select: none; -webkit-user-drag: none; filter: drop-shadow(0 5px 15px rgba(0,0,0,0.1));
        }
        #panda-btn:active { transform: scale(0.8); }

        .shop { margin-top: 20px; display: flex; flex-direction: column; gap: 10px; }
        button { 
            padding: 12px; border: none; border-radius: 12px; 
            background: #689f38; color: white; font-weight: bold; 
            cursor: pointer; transition: 0.2s;
        }
        button:hover:not(:disabled) { background: #33691e; }
        button:disabled { background: #cfd8dc; color: #90a4ae; cursor: not-allowed; }

        #prestige-section {
            margin-top: 20px; padding: 15px; border: 2px dashed #f9a825; border-radius: 15px;
            background: #fff9c4; display: none;
        }
        .prestige-btn { background: #f9a825; color: black; }
        .prestige-btn:hover { background: #f57f17; }
    </style>
</head>
<body>

<div id="game-box">
    <h1>Panda Clicker 🐼</h1>
    <div class="stats">🎋 <span id="bamboo">0</span></div>
    <div class="golden-stats">✨ Golden Multiplier: x<span id="multiplier">1.0</span></div>
    
    <img id="panda-btn" src="https://img.icons8.com/emoji/256/panda-emoji.png" onclick="doClick()">
    
    <div id="friend-display" style="font-size: 30px; height: 40px;"></div>

    <div class="shop">
        <button id="btn-upgrade" onclick="buyUpgrade()">Upgrade Claws (+1/click) | Cost: <span id="cost-upgrade">10</span></button>
        <button id="btn-auto" onclick="buyAuto()">Bamboo Forest (+1/sec) | Cost: <span id="cost-auto">50</span></button>
        <button id="btn-friend" onclick="buyFriend()">Adopt Friend | Cost: 500</button>
    </div>

    <div id="prestige-section">
        <p>You can prestige for <span id="pending-gold">0</span> Golden Bamboo!</p>
        <button class="prestige-btn" onclick="prestige()">RESET FOR GLORY</button>
    </div>

    <p style="font-size: 10px; color: #777; margin-top: 20px; cursor: pointer;" onclick="reset()">Hard Reset Game</p>
</div>

<script>
    // --- Audio Engine ---
    const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    function playNote(freq, type, duration) {
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.type = type;
        osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
        gain.gain.setValueAtTime(0.1, audioCtx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + duration);
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        osc.start();
        osc.stop(audioCtx.currentTime + duration);
    }

    // --- Game Logic ---
    let data = JSON.parse(localStorage.getItem('pandaSave_v3')) || {
        bamboo: 0, clickPower: 1, autoPower: 0,
        costUpgrade: 10, costAuto: 50, hasFriend: false,
        goldenBamboo: 0
    };

    function getMultiplier() {
        return 1 + (data.goldenBamboo * 0.1); // Each Golden Bamboo is +10% boost
    }

    function updateUI() {
        const mult = getMultiplier();
        document.getElementById('bamboo').innerText = Math.floor(data.bamboo);
        document.getElementById('multiplier').innerText = mult.toFixed(1);
        document.getElementById('cost-upgrade').innerText = data.costUpgrade;
        document.getElementById('cost-auto').innerText = data.costAuto;
        
        document.getElementById('btn-upgrade').disabled = data.bamboo < data.costUpgrade;
        document.getElementById('btn-auto').disabled = data.bamboo < data.costAuto;
        
        // Friend Check
        const fBtn = document.getElementById('btn-friend');
        if(data.hasFriend) {
            fBtn.style.display = "none";
            document.getElementById('friend-display').innerText = "🐼💖🐼";
        } else {
            fBtn.disabled = data.bamboo < 500;
        }

        // Prestige Logic: Show if bamboo > 5000
        const prestigeSection = document.getElementById('prestige-section');
        if (data.bamboo >= 5000 || data.goldenBamboo > 0) {
            prestigeSection.style.display = "block";
            let pending = Math.floor(Math.sqrt(data.bamboo / 500));
            document.getElementById('pending-gold').innerText = pending;
        }

        localStorage.setItem('pandaSave_v3', JSON.stringify(data));
    }

    function doClick() {
        data.bamboo += (data.clickPower * getMultiplier());
        playNote(400 + (Math.random() * 100), 'sine', 0.1); // "Pop" sound
        updateUI();
    }

    function buyUpgrade() {
        if(data.bamboo >= data.costUpgrade) {
            data.bamboo -= data.costUpgrade;
            data.clickPower += 1;
            data.costUpgrade = Math.round(data.costUpgrade * 1.5);
            playNote(600, 'triangle', 0.2); // "Success" sound
            updateUI();
        }
    }

    function buyAuto() {
        if(data.bamboo >= data.costAuto) {
            data.bamboo -= data.costAuto;
            data.autoPower += 1;
            data.costAuto = Math.round(data.costAuto * 1.6);
            playNote(800, 'square', 0.1);
            updateUI();
        }
    }

    function buyFriend() {
        if(data.bamboo >= 500) {
            data.bamboo -= 500;
            data.hasFriend = true;
            playNote(1000, 'sine', 0.5);
            updateUI();
        }
    }

    function prestige() {
        let pending = Math.floor(Math.sqrt(data.bamboo / 500));
        if(confirm(`Prestige now for ${pending} Golden Bamboo? You will lose your current bamboo and upgrades, but your earnings will be MUCH faster!`)) {
            data.goldenBamboo += pending;
            data.bamboo = 0;
            data.clickPower = 1;
            data.autoPower = 0;
            data.costUpgrade = 10;
            data.costAuto = 50
