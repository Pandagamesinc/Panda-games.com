<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panda Clicker: Bamboo Tycoon</title>
    <style>
        /* CSS: Making it look polished */
        body { 
            text-align: center; 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
            background-color: #f1f8e9; 
            color: #1b5e20;
            padding: 20px;
        }

        #game-container {
            max-width: 600px;
            margin: 0 auto;
            background: white;
            padding: 30px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        .panda-display {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 20px;
            height: 150px;
        }

        #panda-main { 
            width: 120px; 
            cursor: pointer; 
            transition: transform 0.1s; 
        }

        #panda-main:active { transform: scale(0.9); }

        .friend-panda { width: 80px; animation: bounce 2s infinite; }

        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        .stats { font-size: 28px; margin: 20px 0; font-weight: bold; }

        .shop { 
            display: grid; 
            grid-template-columns: 1fr 1fr; 
            gap: 15px; 
            margin-top: 30px; 
        }

        .upgrade { 
            border: 2px solid #a5d6a7; 
            padding: 15px; 
            border-radius: 15px; 
            background: #f9fbf9; 
        }

        button { 
            background: #4caf50; 
            color: white; 
            border: none; 
            padding: 10px 15px; 
            cursor: pointer; 
            border-radius: 8px;
            font-weight: bold;
            width: 100%;
        }

        button:hover { background: #388e3c; }
        button:disabled { background: #cfd8dc; cursor: not-allowed; }

        .reset-btn { 
            margin-top: 40px; 
            background: #ef5350; 
            width: auto; 
            font-size: 12px;
        }
    </style>
</head>
<body>

    <div id="game-container">
        <h1>Panda Clicker 🐼</h1>
        
        <div class="stats">
            🎋 <span id="bamboo-count">0</span> Bamboo
        </div>

        <div class="panda-display">
            <img id="panda-main" src="https://img.icons8.com/emoji/256/panda-emoji.png" onclick="clickPanda()">
            <div id="friend-container"></div>
        </div>

        <p>Click Power: <span id="click-power">1</span> | Auto: <span id="auto-rate">0</span>/s</p>

        <div class="shop">
            <div class="upgrade">
                <h3>Sharper Claws</h3>
                <p>+1 per click</p>
                <button id="buy-upgrade" onclick="buyUpgrade()">Cost: <span id="upgrade-cost">10</span></button>
            </div>

            <div class="upgrade">
                <h3>Bamboo Forest</h3>
                <p>+1 per second</p>
                <button id="buy-auto" onclick="buyAuto()">Cost: <span id="auto-cost">50</span></button>
            </div>
        </div>

        <div id="special-shop" style="margin-top: 20px;">
            </div>

        <button class="reset-btn" onclick="resetGame()">Reset Progress</button>
    </div>

    <script>
        // --- Game Logic & Persistence ---
        
        // Variables: Load from storage or set defaults
        let bamboo = parseFloat(localStorage.getItem('panda_bamboo')) || 0;
        let clickPower = parseInt(localStorage.getItem('panda_clickPower')) || 1;
        let upgradeCost = parseInt(localStorage.getItem('panda_upgradeCost')) || 10;
        let autoCost = parseInt(localStorage.getItem('panda_autoCost')) || 50;
        let autoRate = parseInt(localStorage.getItem('panda_autoRate')) || 0;
        let hasFriend = localStorage.getItem('panda_hasFriend') === 'true';

        function updateUI() {
            document.getElementById('bamboo-count').innerText = Math.floor(bamboo);
            document.getElementById('click-power').innerText = clickPower;
            document.getElementById('auto-rate').innerText = autoRate;
            document.getElementById('upgrade-cost').innerText = upgradeCost;
            document.getElementById('auto-cost').innerText = autoCost;

            // Button States
            document.getElementById('buy-upgrade').disabled = bamboo < upgradeCost;
            document.getElementById('buy-auto').disabled = bamboo < autoCost;

            // Handle Friend Visuals
            const friendContainer = document.getElementById('friend-container');
            const specialShop = document.getElementById('special-shop');

            if (hasFriend) {
                friendContainer.innerHTML = '<img class="friend-panda" src="https://img.icons8.com/emoji/256/panda-emoji.png" style="filter: sepia(0.5);">';
                specialShop.innerHTML = "<p>✨ You and your friend are happy! ✨</p>";
            } else {
                specialShop.innerHTML = `<button onclick="buyFriend()">Adopt a Panda Friend (500 Bamboo)</button>`;
                document.querySelector('#special-shop button').disabled = bamboo < 500;
            }
        }

        function saveGame() {
            localStorage.setItem('panda_bamboo', bamboo);
            localStorage.setItem('panda_clickPower', clickPower);
            localStorage.setItem('panda_upgradeCost', upgradeCost);
            localStorage.setItem('panda_autoCost', autoCost);
            localStorage.setItem('panda_autoRate', autoRate);
            localStorage.setItem('panda_hasFriend', hasFriend);
        }

        function clickPanda() {
            bamboo += clickPower;
            updateUI();
            saveGame();
        }

        function buyUpgrade() {
            if (bamboo >= upgradeCost) {
                bamboo -= upgradeCost;
                clickPower += 1;
                upgradeCost = Math.round(upgradeCost * 1.6);
                updateUI();
                saveGame();
            }
        }

        function buyAuto() {
            if (bamboo >= autoCost) {
                bamboo -= autoCost;
                autoRate += 1;
                autoCost = Math.round(autoCost * 1.9);
                updateUI();
                saveGame();
            }
        }

        function buyFriend() {
            if (bamboo >= 500) {
                bamboo -= 500;
                hasFriend = true;
                updateUI();
                saveGame();
            }
        }

        function resetGame() {
            if(confirm("Are you sure? You will lose all your bamboo!")) {
                localStorage.clear();
                location.reload(); // Refreshes the page to reset variables
            }
        }

        // Loop for passive income
        setInterval(() => {
            if (autoRate > 0) {
                bamboo += autoRate / 10; // Divided by 10 because it runs every 100ms
                updateUI();
            }
        }, 100); // Smoother updates (10 times per second)

        // Initial update
        updateUI();
    </script>
</body>
</html>
